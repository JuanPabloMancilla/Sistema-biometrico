-- FACULTADES 
-- ===========================================

INSERT OR IGNORE INTO facultad (id_facultad, nombre, estado) VALUES 
(1, 'Facultad de Ciencias Marinas (FACIMAR)', 1),
(2, 'Facultad de Contabilidad y Administración (FCAM)', 1),
(3, 'Escuela de Enfermería', 1),
(4, 'Facultad de Ingeniería Electromecánica (FIE)', 1);

-- ===========================================
-- CARRERAS 
-- ===========================================

-- Ciencias Marinas (FACIMAR) - ID: 1
INSERT OR IGNORE INTO carrera (nombre, id_facultad, estado) VALUES 
('Ingeniería Oceánica', 1, 1),
('Licenciatura en Sustentabilidad Marina', 1, 1);

-- Contabilidad y Administración (FCAM) - ID: 2
INSERT OR IGNORE INTO carrera (nombre, id_facultad, estado) VALUES 
('Contador Público', 2, 1),
('Licenciatura en Administración', 2, 1),
('Licenciatura en Negocios Digitales', 2, 1);

-- Escuela de Enfermería - ID: 3
INSERT OR IGNORE INTO carrera (nombre, id_facultad, estado) VALUES 
('Licenciatura en Enfermería', 3, 1);

-- Ingeniería Electromecánica (FIE) - ID: 4
INSERT OR IGNORE INTO carrera (nombre, id_facultad, estado) VALUES 
('Ingeniero Mecánico Electricista (IME)', 4, 1),
('Ingeniería en Tecnologías Electrónicas (ITE)', 4, 1),
('Ingeniería en Mecatrónica (IMT)', 4, 1),
('Ingeniería de Software (IS)', 4, 1);

-- ===========================================
-- ROL ADMIN 
-- ===========================================

INSERT OR IGNORE INTO usuario_rol (id_rol, nombre, descripcion) VALUES 
(1, 'admin', 'Administrador del sistema');

-- ===========================================
-- TU USUARIO 
-- ===========================================

INSERT OR IGNORE INTO usuario (nombre, a_paterno, a_materno, fecha_registro, id_rol, id_facultad, id_carrera)
VALUES ('Juan Pablo', 'Mancilla', 'Rodriguez', datetime('now'), 1, 4, 10);</sql><current_tab id="0"/></tab_sql></sqlb_project>
